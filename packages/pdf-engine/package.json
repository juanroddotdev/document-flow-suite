{
  "name": "@document-flow/pdf-engine",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "default": "./dist/index.js" },
    "./worker": { "types": "./dist/worker.d.ts", "import": "./dist/worker.js", "default": "./dist/worker.js" }
  },
  "scripts": {
    "build": "tsup src/index.ts src/worker.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "browser-image-compression": "^2.0.2",
    "heic2any": "^0.0.4",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.7.76",
    "utif": "^3.1.0"
  },
  "devDependencies": {
    "happy-dom": "^15.11.7",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "vitest": "^2.1.6"
  }
}
